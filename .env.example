# Obolus Configuration
# Copy this file to .env and customize

# Ollama API endpoint
OLLAMA_URL=http://localhost:11434

# Default model (overridden by auto-discovery in evolve mode)
OBULUS_MODEL=qwen2.5-coder:7b

# Token budget per inference round
OBULUS_TOKENS_PER_ROUND=2048

# Starting balance for agents in the evolutionary arena ($OBL)
OBULUS_INITIAL_BALANCE=100.0
