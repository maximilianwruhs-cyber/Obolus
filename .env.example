# Obolus Configuration
# Copy this file to .env and customize

# Ollama API endpoint
OLLAMA_URL=http://localhost:11434

# Default model (bench auto-discovery overrides when models are present)
OBULUS_MODEL=qwen2.5-coder:7b

# Electricity: offline by default (no network). Set OBULUS_PRICE_SOURCE=awattar for live AT spot.
OBULUS_ELECTRICITY_C_KWH=25.0
OBULUS_PRICE_SOURCE=offline

# Token budget per inference round (experimental evolve path)
OBULUS_TOKENS_PER_ROUND=2048

# Starting balance for agents in the evolutionary arena (experimental)
OBULUS_INITIAL_BALANCE=100.0

# Optional Arena organ hints (Phase 11). Absent = stranger path unchanged.
# Copy data/organ_hints.example.json → data/organ_hints.json, or set a path:
# OBULUS_ORGAN_HINTS=/path/to/organ_hints.json
